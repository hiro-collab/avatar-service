{
  "name": "avatar-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:detached": "node scripts/dev-server.mjs start",
    "dev:stop": "node scripts/dev-server.mjs stop",
    "dev:status": "node scripts/dev-server.mjs status",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.2",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/three": "^0.184.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.0"
  }
}
